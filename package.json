{
  "name": "nuref",
  "version": "1.0.1",
  "description": "Universal Feed Processing Engine - Fetch, parse, normalize, search, deduplicate, aggregate, compare, stream, and generate any feed format",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nuref": "dist/cli/index.js",
    "nuref-api": "dist/api/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run dist/index.js",
    "run": "bun run dist/cli/index.js",
    "cli": "bun run src/cli/index.ts",
    "test": "bun run src/tests/engine.test.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "pack:deb": "bash scripts/build-deb.sh",
    "pack:rpm": "bash scripts/build-rpm.sh",
    "pack:all": "bash scripts/build-packages.sh",
    "setup-repo": "bash scripts/setup-repo.sh"
  },
  "keywords": [
    "rss",
    "atom",
    "rdf",
    "json-feed",
    "sitemap",
    "feed",
    "xml",
    "parser",
    "aggregator",
    "aggregator",
    "fetch",
    "normalize",
    "search",
    "deduplicate",
    "webhook",
    "scheduler",
    "cli",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nullgang/nuref.git"
  },
  "homepage": "https://github.com/nullgang/nuref",
  "bugs": {
    "url": "https://github.com/nullgang/nuref/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "hono": "^4.6.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "undici": "^6.19.0"
  }
}
