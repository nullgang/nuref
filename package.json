{
  "name": "nuref",
  "version": "1.0.0",
  "description": "Universal Feed Processing Engine - Fetch, parse, normalize, search, and generate any feed format",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nuref": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["rss", "atom", "feed", "xml", "parser", "aggregator"],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "hono": "^4.6.0",
    "node-cron": "^3.0.3",
    "undici": "^6.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
